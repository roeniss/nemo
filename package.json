{
  "name": "nemo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:local": "wrangler d1 execute quick-memo-db --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute quick-memo-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "marked": "^18.0.5",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@preact/preset-vite": "^2.10.5",
    "@vitest/runner": "^4.1.8",
    "@vitest/snapshot": "^4.1.8",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.0.0"
  }
}
