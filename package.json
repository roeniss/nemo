{
  "name": "nemo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "db:local": "wrangler d1 execute nemo-db --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute nemo-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "hono": "^4.6.14",
    "marked": "^18.0.5",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20260607.1",
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/runner": "^4.1.8",
    "@vitest/snapshot": "^4.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.0.0"
  }
}
